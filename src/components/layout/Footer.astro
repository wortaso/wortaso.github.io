---
import { siteConfig } from "@/config/site";
import { getLangFromUrl, useTranslations, getLocalizedPath } from "@/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="mt-20 border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div
      class="flex flex-col items-center gap-2 text-center text-xs text-muted-foreground"
    >
      <a href={getLocalizedPath("/privacy-policy", lang)} class="hover:text-primary transition-colors">{t.footer.privacy}</a>
      <span>&copy; {new Date().getFullYear()} {siteConfig.author}. {t.footer.copyright}</span>
    </div>
  </div>
</footer>

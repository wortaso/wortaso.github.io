---
import { siteConfig } from "@/config/site";
---

<footer class="mt-20 border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div
      class="flex flex-col items-center gap-2 text-center text-xs text-muted-foreground"
    >
      <a href="/privacy-policy" class="hover:text-primary transition-colors">Privacy Policy</a>
      <span>&copy; {new Date().getFullYear()} {siteConfig.author}. All rights reserved.</span>
    </div>
  </div>
</footer>

---
import type { ImageMetadata } from "astro";
import { getLangFromUrl } from "@/i18n";
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string | ImageMetadata;
  ignoreTitleTemplate?: boolean;
  noindex?: boolean;
  alternateHref?: string;
}

import { siteConfig } from "@/config/site";

const {
  title,
  description = siteConfig.description,
  canonical,
  ogImage = undefined,
  ignoreTitleTemplate = false,
  noindex = false,
  alternateHref,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const selfHref = new URL(Astro.url.pathname, siteConfig.url).toString();
const altHref = alternateHref
  ? new URL(alternateHref, siteConfig.url).toString()
  : undefined;

const ogImageSrc = ogImage
  ? typeof ogImage === "string"
    ? ogImage
    : ogImage.src
  : undefined;

const fullTitle =
  title && !ignoreTitleTemplate
    ? `${title} | ${siteConfig.name}`
    : title || siteConfig.name;
const canonicalURL =
  canonical ?? new URL(Astro.url.pathname, siteConfig.url).toString();
---

<!-- Global Metadata -->{
  noindex && <meta name="robots" content="noindex, nofollow" />
}
{
  altHref && (
    <>
      <link
        rel="alternate"
        hreflang={lang === "de" ? "de" : "en"}
        href={selfHref}
      />
      <link
        rel="alternate"
        hreflang={lang === "de" ? "en" : "de"}
        href={altHref}
      />
      <link
        rel="alternate"
        hreflang="x-default"
        href={lang === "de" ? altHref : selfHref}
      />
    </>
  )
}
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="canonical" href={canonicalURL} />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
{
  ogImageSrc && (
    <meta property="og:image" content={new URL(ogImageSrc, siteConfig.url)} />
  )
}
<meta property="og:locale" content={siteConfig.locale} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
{
  ogImageSrc && (
    <meta
      property="twitter:image"
      content={new URL(ogImageSrc, siteConfig.url)}
    />
  )
}
{
  siteConfig.twitter && (
    <meta property="twitter:creator" content={siteConfig.twitter} />
  )
}

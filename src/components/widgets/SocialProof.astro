---
interface Props {
  rating: string;
  platform: string;
  label: string;
  reviewCount: string;
  ctaText?: string;
  storeUrl: string;
}

const { rating, platform, label, reviewCount, ctaText, storeUrl } = Astro.props;
---

<section class="py-12 md:py-16 reveal">
  <div class="mx-auto max-w-3xl px-4 text-center">
    {
      ctaText && (
        <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-4">
          {ctaText}
        </p>
      )
    }
    <a
      href={storeUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex flex-col items-center gap-2 group"
      aria-label={label}
    >
      <!-- Stars -->
      <div class="flex gap-1" aria-hidden="true">
        {
          [1, 2, 3, 4, 5].map(() => (
            <svg
              class="w-7 h-7 text-yellow-400 fill-yellow-400"
              viewBox="0 0 24 24"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))
        }
      </div>
      <!-- Rating number -->
      <span
        class="text-4xl font-bold tracking-tight group-hover:text-primary transition-colors"
      >
        {rating}
      </span>
      <!-- Platform + review count -->
      <span class="text-muted-foreground text-sm">
        {platform} &middot; {reviewCount}
      </span>
    </a>
  </div>
</section>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Features from "@/components/widgets/Features.astro";
import FeatureShowcase from "@/components/widgets/FeatureShowcase.astro";
import SocialProof from "@/components/widgets/SocialProof.astro";
import CtaBanner from "@/components/widgets/CtaBanner.astro";
import Schema from "@/components/seo/Schema.astro";
import { useTranslations } from "@/i18n";

const t = useTranslations("en");

const metadata = {
  title: "Wortaso — Learn German Vocabulary | 12,000+ Words, SRS, Zero Ads",
  description:
    "Learn German vocabulary with 12,000+ words, color-coded articles, exam prep lists (Einbürgerungstest & Führerschein), smart SRS, and zero ads. Available on Google Play.",
  ignoreTitleTemplate: true,
  alternateHref: "/de",
};

const featureIcons = [
  { icon: "lucide:library", iconClass: "bg-blue-500/10 text-blue-400" },
  { icon: "lucide:palette", iconClass: "bg-green-500/10 text-green-400" },
  { icon: "lucide:quote", iconClass: "bg-yellow-500/10 text-yellow-400" },
  {
    icon: "lucide:graduation-cap",
    iconClass: "bg-purple-500/10 text-purple-400",
  },
  { icon: "lucide:list", iconClass: "bg-orange-500/10 text-orange-400" },
  { icon: "lucide:brain", iconClass: "bg-pink-500/10 text-pink-400" },
  { icon: "lucide:bookmark", iconClass: "bg-teal-500/10 text-teal-400" },
  { icon: "lucide:shield-off", iconClass: "bg-red-500/10 text-red-400" },
];
---

<BaseLayout {metadata}>
  <Fragment slot="head">
    <Schema type="SoftwareApplication" data={{}} />
  </Fragment>

  <!-- ── HERO ──────────────────────────────────────────────────────── -->
  <section class="relative px-4 py-20 md:py-32">
    <div
      class="mx-auto max-w-6xl flex flex-col md:flex-row items-center gap-12 md:gap-16"
    >
      <!-- Text side -->
      <div class="flex-1 text-center md:text-left">
        <p
          class="text-sm font-semibold uppercase tracking-widest text-primary mb-3"
        >
          {t.hero.tagline}
        </p>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-5 leading-tight"
        >
          {
            t.hero.title.split("\n").map((line: string, i: number) => (
              <span>
                {i === 1 ? <span class="text-primary">{line}</span> : line}
                {i === 0 && <br />}
              </span>
            ))
          }
        </h1>
        <p class="text-lg text-muted-foreground mb-10 max-w-lg mx-auto md:mx-0">
          {t.hero.subtitle}
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start"
        >
          <!-- App Store — waitlist modal -->
          <button
            id="ios-waitlist-btn"
            type="button"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-black text-white px-8 py-4 text-base font-semibold shadow-md hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 dark:bg-white dark:text-black cursor-pointer"
          >
            <svg
              class="w-5 h-5 shrink-0"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
              ></path>
            </svg>
            {t.hero.appStore}
          </button>

          <!-- Google Play -->
          <a
            href="https://play.google.com/store/apps/details?id=com.wortaso.app&hl=en"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#01875f] text-white px-8 py-4 text-base font-semibold shadow-md hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200"
          >
            <svg
              class="w-5 h-5 shrink-0"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"
              ></path>
            </svg>
            {t.hero.googlePlay}
          </a>
        </div>
      </div>

      <!-- Screenshot side -->
      <div class="flex-none flex justify-center">
        <img
          src="/app/screenshot-1.png"
          alt={t.screenshots.alt[0]}
          width="280"
          height="607"
          loading="eager"
          decoding="async"
          class="w-[220px] md:w-[280px] rounded-[2rem] shadow-2xl ring-1 ring-border"
        />
      </div>
    </div>
  </section>

  <!-- ── FEATURE SHOWCASE (alternating) ──────────────────────────── -->
  <FeatureShowcase
    sections={t.featureSections.map(
      (s: (typeof t.featureSections)[0], i: number) => ({
        ...s,
        imageSrc: `/app/screenshot-${[2, 3, 7, 5][i]}.png`,
      }),
    )}
  />

  <!-- ── FEATURES GRID ─────────────────────────────────────────────  -->
  <Features
    tagline={t.features.tagline}
    title={t.features.title}
    subtitle={t.features.subtitle}
    columns={4}
    features={t.features.items.map(
      (item: (typeof t.features.items)[0], i: number) => ({
        title: item.title,
        description: item.description,
        icon: featureIcons[i].icon,
        iconClass: featureIcons[i].iconClass,
      }),
    )}
  />

  <!-- ── SOCIAL PROOF ──────────────────────────────────────────────  -->
  <SocialProof
    rating={t.socialProof.rating}
    platform={t.socialProof.platform}
    label={t.socialProof.label}
    reviewCount={t.socialProof.reviewCount}
    ctaText={t.socialProof.ctaText}
    storeUrl="https://play.google.com/store/apps/details?id=com.wortaso.app"
  />

  <!-- ── CTA BANNER ────────────────────────────────────────────────  -->
  <CtaBanner
    tagline={t.cta.tagline}
    title={t.cta.title}
    subtitle={t.cta.subtitle}
    appStoreLabel={t.cta.appStore}
    googlePlayLabel={t.cta.googlePlay}
    googlePlayUrl="https://play.google.com/store/apps/details?id=com.wortaso.app&hl=en"
    appStoreModalId="waitlist-modal"
  />

  <!-- ── iOS WAITLIST MODAL ─────────────────────────────────────────  -->
  <dialog
    id="waitlist-modal"
    class="m-auto rounded-2xl shadow-2xl p-0 w-full max-w-md backdrop:bg-black/50 backdrop:backdrop-blur-sm"
  >
    <div class="bg-background text-foreground rounded-2xl p-8 relative">
      <button
        id="waitlist-close"
        type="button"
        aria-label="Close"
        class="absolute top-4 right-4 text-muted-foreground hover:text-foreground transition-colors text-xl leading-none"
        >&times;</button
      >

      <div class="mb-6 text-center">
        <div
          class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-black dark:bg-white mb-4"
        >
          <svg
            class="w-6 h-6 text-white dark:text-black"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold mb-2">iOS App — Coming Soon</h2>
        <p class="text-muted-foreground text-sm">
          Join the waitlist and we'll notify you when it launches.
        </p>
      </div>

      <form id="waitlist-form" novalidate>
        <div class="mb-4">
          <label for="waitlist-email" class="block text-sm font-medium mb-1"
            >Email address</label
          >
          <input
            type="email"
            id="waitlist-email"
            name="email"
            required
            placeholder="you@example.com"
            class="block w-full rounded-xl border border-border bg-muted/50 px-4 py-3 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-4 focus:ring-primary/20 focus:border-primary transition-all"
          />
        </div>
        <button
          type="submit"
          class="w-full inline-flex items-center justify-center rounded-xl bg-black text-white dark:bg-white dark:text-black px-6 py-3 font-semibold shadow-md hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200"
        >
          Notify Me
        </button>
      </form>

      <p id="waitlist-msg" class="mt-4 text-center text-sm hidden"></p>
    </div>
  </dialog>

  <script>
    const btn = document.getElementById(
      "ios-waitlist-btn",
    ) as HTMLButtonElement;
    const modal = document.getElementById(
      "waitlist-modal",
    ) as HTMLDialogElement;
    const closeBtn = document.getElementById(
      "waitlist-close",
    ) as HTMLButtonElement;
    const form = document.getElementById("waitlist-form") as HTMLFormElement;
    const msg = document.getElementById("waitlist-msg") as HTMLParagraphElement;

    btn.addEventListener("click", () => {
      msg.classList.add("hidden");
      msg.textContent = "";
      (form.querySelector("#waitlist-email") as HTMLInputElement).value = "";
      modal.showModal();
    });

    closeBtn.addEventListener("click", () => modal.close());

    modal.addEventListener("click", (e) => {
      if (e.target === modal) modal.close();
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector(
        "[type=submit]",
      ) as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";

      const data = new FormData(form);
      try {
        const res = await fetch("https://formspree.io/f/xaqpdvko", {
          method: "POST",
          body: data,
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          form.classList.add("hidden");
          msg.textContent =
            "You're on the list! We'll email you when the iOS app launches.";
          msg.className =
            "mt-4 text-center text-sm text-green-600 dark:text-green-400";
        } else {
          msg.textContent = "Something went wrong. Please try again.";
          msg.className =
            "mt-4 text-center text-sm text-red-600 dark:text-red-400";
          submitBtn.disabled = false;
          submitBtn.textContent = "Notify Me";
        }
      } catch {
        msg.textContent = "Network error. Please try again.";
        msg.className =
          "mt-4 text-center text-sm text-red-600 dark:text-red-400";
        submitBtn.disabled = false;
        submitBtn.textContent = "Notify Me";
      }
    });
  </script>
</BaseLayout>

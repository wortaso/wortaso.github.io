---
import BaseLayout from "@/layouts/BaseLayout.astro";

const metadata = {
  title: "Der Die Das Cheat Sheet: Complete Guide to German Articles",
  description:
    "The ultimate der die das cheat sheet. Learn every German article rule by noun ending and meaning — der, die, das at a glance. Free reference for German learners.",
  canonical: "/der-die-das-cheatsheet",
  alternateHref: "/de/der-die-das-spickzettel",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is a der die das cheat sheet?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A der die das cheat sheet is a compact reference guide that lists the rules for choosing German articles (der, die, das) based on noun endings (suffixes) and semantic categories. Instead of memorising every noun individually, learners can use these patterns to predict the correct article in most cases.",
      },
    },
    {
      "@type": "Question",
      name: "How many articles does German have?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "German has three definite articles: der (masculine), die (feminine), and das (neuter). In the plural, all nouns use die regardless of their singular gender.",
      },
    },
    {
      "@type": "Question",
      name: "What noun endings always use 'die' (feminine)?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "-heit and -keit are 100% feminine (e.g. die Freiheit, die Höflichkeit). -ung is 99% feminine (e.g. die Zeitung). Other highly reliable feminine endings include -schaft, -ion, -ität, -ik, -anz, -enz, and -ur.",
      },
    },
    {
      "@type": "Question",
      name: "What noun endings always use 'das' (neuter)?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "-chen and -lein are always neuter (100%) — e.g. das Mädchen, das Fräulein. Other reliable neuter endings include -ment, -um, -ma, and -tum.",
      },
    },
    {
      "@type": "Question",
      name: "What are the most reliable masculine (der) endings?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The most reliable masculine endings are -ig (der Honig), -ling (der Schmetterling), -ismus (der Optimismus), -or (der Motor), -ant (der Elefant), and -ich (der Teppich). These are all highly reliable indicators of der.",
      },
    },
    {
      "@type": "Question",
      name: "What article do all German plural nouns use?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "All German plural nouns use die, regardless of the singular article. For example: der Mann → die Männer, das Kind → die Kinder, die Frau → die Frauen.",
      },
    },
    {
      "@type": "Question",
      name: "How do compound nouns work in German?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In German compound nouns, the article is always determined by the last word in the compound. For example: der Tisch + die Decke = die Tischdecke; die Hand + der Schuh = der Handschuh.",
      },
    },
  ],
};
---

<BaseLayout {metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold tracking-tight mb-4">
      Der Die Das Cheat Sheet: The Ultimate Guide
    </h1>
    <p class="text-muted-foreground mb-3">
      Choosing the right German article — <strong>der</strong>, <strong
        >die</strong
      >, or <strong>das</strong> — is one of the hardest parts of learning German.
      This der die das cheat sheet gives you every reliable rule in one place: predictable
      noun endings (suffixes) and meaning-based categories so you can stop guessing
      and start applying patterns.
    </p>
    <p class="text-muted-foreground mb-10">
      Use it as a quick-reference during study sessions or alongside the <a
        href="https://apps.apple.com/app/wortaso/id6473643421"
        class="text-primary underline underline-offset-2 hover:text-primary/80"
        target="_blank"
        rel="noopener noreferrer">Wortaso app</a
      > to reinforce each rule with spaced repetition across 10,000+ nouns.
    </p>

    <!-- Table of Contents -->
    <nav class="mb-10 rounded-xl border border-border bg-muted/50 px-6 py-5">
      <p class="text-sm font-semibold uppercase tracking-widest text-muted-foreground mb-3">Contents</p>
      <ol class="space-y-1 text-sm">
        <li><a href="#masculine" class="text-primary hover:underline">1. Masculine (Der)</a></li>
        <li><a href="#feminine" class="text-primary hover:underline">2. Feminine (Die)</a></li>
        <li><a href="#neuter" class="text-primary hover:underline">3. Neuter (Das)</a></li>
        <li><a href="#special-rules" class="text-primary hover:underline">4. Special Rules</a></li>
        <li><a href="#faq" class="text-primary hover:underline">5. Frequently Asked Questions</a></li>
      </ol>
    </nav>

    <!-- 1. Masculine -->
    <section class="mb-12">
      <h2 id="masculine" class="text-2xl font-bold mb-6">1. Masculine (Der)</h2>

      <h3 class="text-lg font-semibold mb-3">By Suffix</h3>
      <div class="overflow-x-auto mb-6">
        <table
          class="w-full text-sm border border-border rounded-lg overflow-hidden"
        >
          <thead class="bg-muted text-muted-foreground">
            <tr>
              <th class="text-left px-4 py-2 font-semibold">Ending</th>
              <th class="text-left px-4 py-2 font-semibold">Reliability</th>
              <th class="text-left px-4 py-2 font-semibold">Example</th>
            </tr>
          </thead>
          <tbody>
            {
              [
                ["‑ig", "High", "der Honig"],
                ["‑ling", "High", "der Schmetterling"],
                ["‑ismus", "High", "der Optimismus"],
                ["‑or", "High", "der Motor"],
                ["‑ant", "High", "der Elefant"],
                ["‑ich", "High", "der Teppich"],
                ["‑er", "Medium", "der Lehrer"],
              ].map(([ending, reliability, example], i) => (
                <tr
                  class:list={[
                    "border-t border-border",
                    i % 2 === 0 ? "" : "bg-muted/30",
                  ]}
                >
                  <td class="px-4 py-2 font-mono font-semibold">{ending}</td>
                  <td class="px-4 py-2">{reliability}</td>
                  <td class="px-4 py-2 italic">{example}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold mb-3">By Meaning</h3>
      <ul class="list-disc pl-6 space-y-1 text-sm">
        <li><strong>Days, Months, Seasons:</strong> Montag, Juli, Sommer.</li>
        <li><strong>Weather:</strong> Regen, Schnee, Wind.</li>
        <li><strong>Directions:</strong> Norden, Süden, Osten, Westen.</li>
        <li><strong>Alcohol:</strong> Wein, Wodka, Gin.</li>
        <li><strong>Car Brands:</strong> VW, Audi, BMW.</li>
      </ul>
    </section>

    <!-- 2. Feminine -->
    <section class="mb-12">
      <h2 id="feminine" class="text-2xl font-bold mb-6">2. Feminine (Die)</h2>

      <h3 class="text-lg font-semibold mb-3">By Suffix</h3>
      <div class="overflow-x-auto mb-6">
        <table
          class="w-full text-sm border border-border rounded-lg overflow-hidden"
        >
          <thead class="bg-muted text-muted-foreground">
            <tr>
              <th class="text-left px-4 py-2 font-semibold">Ending</th>
              <th class="text-left px-4 py-2 font-semibold">Reliability</th>
              <th class="text-left px-4 py-2 font-semibold">Example</th>
            </tr>
          </thead>
          <tbody>
            {
              [
                ["‑ung", "99%", "die Zeitung"],
                ["‑heit", "100%", "die Freiheit"],
                ["‑keit", "100%", "die Höflichkeit"],
                ["‑schaft", "High", "die Freundschaft"],
                ["‑ei", "High", "die Bäckerei"],
                ["‑in", "High", "die Studentin"],
                ["‑ion", "High", "die Station"],
                ["‑ität", "High", "die Universität"],
                ["‑ik", "High", "die Musik"],
                ["‑ur", "High", "die Natur"],
                ["‑anz / ‑enz", "High", "die Distanz"],
                ["‑e", "Medium", "die Lampe"],
              ].map(([ending, reliability, example], i) => (
                <tr
                  class:list={[
                    "border-t border-border",
                    i % 2 === 0 ? "" : "bg-muted/30",
                  ]}
                >
                  <td class="px-4 py-2 font-mono font-semibold">{ending}</td>
                  <td class="px-4 py-2">{reliability}</td>
                  <td class="px-4 py-2 italic">{example}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold mb-3">By Meaning</h3>
      <ul class="list-disc pl-6 space-y-1 text-sm">
        <li><strong>Numbers:</strong> die Eins, die Zehn.</li>
        <li><strong>Trees &amp; Flowers:</strong> die Eiche, die Rose.</li>
        <li>
          <strong>Ships &amp; Aircraft:</strong> die Titanic, die Boeing 747.
        </li>
      </ul>
    </section>

    <!-- 3. Neuter -->
    <section class="mb-12">
      <h2 id="neuter" class="text-2xl font-bold mb-6">3. Neuter (Das)</h2>

      <h3 class="text-lg font-semibold mb-3">By Suffix</h3>
      <div class="overflow-x-auto mb-6">
        <table
          class="w-full text-sm border border-border rounded-lg overflow-hidden"
        >
          <thead class="bg-muted text-muted-foreground">
            <tr>
              <th class="text-left px-4 py-2 font-semibold">Ending</th>
              <th class="text-left px-4 py-2 font-semibold">Reliability</th>
              <th class="text-left px-4 py-2 font-semibold">Example</th>
            </tr>
          </thead>
          <tbody>
            {
              [
                ["‑chen", "100%", "das Mädchen"],
                ["‑lein", "100%", "das Fräulein"],
                ["‑ment", "High", "das Dokument"],
                ["‑um", "High", "das Zentrum"],
                ["‑ma", "High", "das Thema"],
                ["‑tum", "Medium", "das Eigentum"],
              ].map(([ending, reliability, example], i) => (
                <tr
                  class:list={[
                    "border-t border-border",
                    i % 2 === 0 ? "" : "bg-muted/30",
                  ]}
                >
                  <td class="px-4 py-2 font-mono font-semibold">{ending}</td>
                  <td class="px-4 py-2">{reliability}</td>
                  <td class="px-4 py-2 italic">{example}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold mb-3">By Meaning</h3>
      <ul class="list-disc pl-6 space-y-1 text-sm">
        <li>
          <strong>Diminutives:</strong> All words ending in <em>‑chen</em> or <em
            >‑lein</em
          >.
        </li>
        <li>
          <strong>Infinitives as Nouns:</strong> das Essen, das Schwimmen, das Lesen.
        </li>
        <li><strong>Colors:</strong> das Blau, das Rot.</li>
        <li><strong>Metals &amp; Elements:</strong> das Gold, das Helium.</li>
        <li><strong>Fractions:</strong> das Drittel, das Viertel.</li>
      </ul>
    </section>

    <!-- 4. Special Rules -->
    <section class="mb-12">
      <h2 id="special-rules" class="text-2xl font-bold mb-6">4. Special Rules</h2>

      <h3 class="text-lg font-semibold mb-2">The "Ge-" Prefix</h3>
      <p class="text-sm mb-2">
        Nouns starting with <strong>Ge-</strong> are usually <strong
          >Neuter</strong
        >.
      </p>
      <ul class="list-disc pl-6 space-y-1 text-sm mb-6">
        <li><em>das Gebäude, das Gesetz, das Gespräch.</em></li>
      </ul>

      <h3 class="text-lg font-semibold mb-2">Compound Nouns</h3>
      <p class="text-sm mb-2">
        The article is always determined by the <strong>last word</strong> in the
        chain.
      </p>
      <ul class="list-disc pl-6 space-y-1 text-sm mb-6">
        <li>
          der Tisch + <strong>die</strong> Decke = <strong>die</strong> Tischdecke
        </li>
        <li>
          die Hand + <strong>der</strong> Schuh = <strong>der</strong> Handschuh
        </li>
      </ul>

      <h3 class="text-lg font-semibold mb-2">Plurals</h3>
      <p class="text-sm mb-2">
        In the plural form, the article is <strong>always "die"</strong>.
      </p>
      <ul class="list-disc pl-6 space-y-1 text-sm">
        <li>der Mann → die Männer</li>
        <li>das Kind → die Kinder</li>
      </ul>
    </section>

    <!-- 5. FAQ -->
    <section class="mb-12">
      <h2 id="faq" class="text-2xl font-bold mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-base font-semibold mb-1">
            What is a der die das cheat sheet?
          </h3>
          <p class="text-sm text-muted-foreground">
            A der die das cheat sheet is a compact reference that lists rules
            for choosing German articles based on noun endings and semantic
            categories. Instead of memorising every noun individually, you apply
            predictable patterns that cover the vast majority of cases.
          </p>
        </div>

        <div>
          <h3 class="text-base font-semibold mb-1">
            How many articles does German have?
          </h3>
          <p class="text-sm text-muted-foreground">
            German has three definite articles: <strong>der</strong> (masculine),
            <strong>die</strong> (feminine), and <strong>das</strong> (neuter). In
            the plural, all nouns use <strong>die</strong> regardless of their singular
            gender.
          </p>
        </div>

        <div>
          <h3 class="text-base font-semibold mb-1">
            What noun endings always use "die"?
          </h3>
          <p class="text-sm text-muted-foreground">
            <strong>‑heit</strong> and <strong>‑keit</strong> are 100% feminine (die
            Freiheit, die Höflichkeit). <strong>‑ung</strong> is 99% feminine (die
            Zeitung). Other highly reliable feminine endings include ‑schaft, ‑ion,
            ‑ität, ‑ik, ‑anz, ‑enz, and ‑ur.
          </p>
        </div>

        <div>
          <h3 class="text-base font-semibold mb-1">
            What noun endings always use "das"?
          </h3>
          <p class="text-sm text-muted-foreground">
            <strong>‑chen</strong> and <strong>‑lein</strong> are always neuter (100%)
            — das Mädchen, das Fräulein. Other reliable neuter endings include ‑ment,
            ‑um, ‑ma, and ‑tum.
          </p>
        </div>

        <div>
          <h3 class="text-base font-semibold mb-1">
            What are the most reliable "der" endings?
          </h3>
          <p class="text-sm text-muted-foreground">
            The most reliable masculine endings are <strong>‑ig</strong> (der Honig),
            <strong>‑ling</strong> (der Schmetterling), <strong>‑ismus</strong>
            (der Optimismus), <strong>‑or</strong> (der Motor), <strong
              >‑ant</strong
            > (der Elefant), and <strong>‑ich</strong> (der Teppich).
          </p>
        </div>

        <div>
          <h3 class="text-base font-semibold mb-1">
            What article do all German plural nouns use?
          </h3>
          <p class="text-sm text-muted-foreground">
            All German plural nouns use <strong>die</strong>, regardless of the
            singular article. For example: der Mann → die Männer, das Kind → die
            Kinder, die Frau → die Frauen.
          </p>
        </div>

        <div>
          <h3 class="text-base font-semibold mb-1">
            How do compound nouns work in German?
          </h3>
          <p class="text-sm text-muted-foreground">
            In German compound nouns, the article is always determined by the <strong
              >last word</strong
            > in the compound. Example: der Tisch + die Decke = <strong
              >die</strong
            > Tischdecke; die Hand + der Schuh = <strong>der</strong> Handschuh.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
